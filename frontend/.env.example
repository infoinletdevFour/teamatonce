# ==========================================
# Team@Once Frontend - Environment Template
# ==========================================
# Copy this file to .env.local for local development
# or .env.production for production deployment
# ==========================================

# API Configuration
# ==========================================
# Backend API base URL (without trailing slash)
# Local: http://localhost:3001/api/v1
# Production: https://api.teamatonce.com/api/v1
VITE_API_URL=http://localhost:3001/api/v1

# WebSocket Configuration
# ==========================================
# WebSocket server URL for real-time features
# Local: http://localhost:3001
# Production: https://api.teamatonce.com
VITE_WS_URL=http://localhost:3001

# Application Configuration
# ==========================================
# Application mode: development | staging | production
VITE_APP_ENV=development

# Application base URL
# Local: http://localhost:5173
# Production: https://teamatonce.com
VITE_APP_URL=http://localhost:5173

# Feature Flags
# ==========================================
# Enable/disable analytics (true | false)
VITE_ENABLE_ANALYTICS=false

# Enable/disable error tracking with Sentry (true | false)
VITE_ENABLE_ERROR_TRACKING=false

# Enable/disable debug mode with detailed logs (true | false)
VITE_ENABLE_DEBUG_MODE=true

# Authentication Configuration
# ==========================================
# GitHub OAuth Client ID
# Get from: https://github.com/settings/developers
VITE_GITHUB_CLIENT_ID=your-github-client-id

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# NextAuth/Auth.js URL (should match your app URL)
VITE_NEXTAUTH_URL=http://localhost:5173

# NextAuth/Auth.js secret (generate with: openssl rand -base64 32)
VITE_NEXTAUTH_SECRET=

# Payment Configuration
# ==========================================
# Stripe Publishable Key
# Test: pk_test_...
# Live: pk_live_...
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# AI/ML Configuration (Optional)
# ==========================================
# OpenAI API Key (use with caution - prefer backend calls)
# Get from: https://platform.openai.com/api-keys
# VITE_OPENAI_API_KEY=

# Storage Configuration (Optional)
# ==========================================
# AWS S3 Configuration (if using direct frontend uploads)
# VITE_AWS_REGION=
# VITE_AWS_BUCKET=

# Google Cloud Storage (if using direct frontend uploads)
# VITE_GCS_BUCKET=

# Analytics & Monitoring (Optional)
# ==========================================
# Google Analytics 4 Measurement ID (GA4 format: G-XXXXXXXXXX)
# Get from: https://analytics.google.com
# Used by utils/analytics.ts for event tracking
VITE_GA_MEASUREMENT_ID=

# Google Analytics Tracking ID (Legacy - deprecated, use GA_MEASUREMENT_ID instead)
# VITE_GA_TRACKING_ID=

# Sentry DSN for error tracking
# Get from: https://sentry.io
VITE_SENTRY_DSN=

# Misc Configuration
# ==========================================
# Maximum file upload size in MB (default: 10 for dev, 25 for prod)
VITE_MAX_FILE_SIZE=10

# API request timeout in milliseconds (default: 30000 for dev, 60000 for prod)
VITE_API_TIMEOUT=30000

# Enable API request logging (true | false)
VITE_LOG_API_REQUESTS=true

# Default language/locale (en | de | it | fr | zh | es | ja | ko | pt | ru | ar)
VITE_DEFAULT_LOCALE=en

# Supported locales (comma-separated list)
VITE_SUPPORTED_LOCALES=en,de,it,fr,zh,es,ja,ko,pt,ru,ar
